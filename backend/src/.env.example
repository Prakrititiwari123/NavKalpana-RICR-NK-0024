# copy this file to .env and fill in real values
PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.example.mongodb.net/dbname

# Cloudinary configuration
CLOUDNARY_CLOUD_NAME=
CLOUDNARY_API_KEY=
CLOUDNARY_API_SECRET=

# Gmail (for nodemailer)
GMAIL_USER=
GMAIL_PASSCODE=

# Groq API (AI features)
GROQ_API_KEY=

# CORS origins whitelist, comma separated
CORS_ORIGINS=https://your-frontend-domain.com,https://another-domain.com

# secrets for tokens
ACCESS_SECRET=
REFRESH_SECRET=
JWT_SECRET=

# set to "production" when deployed
NODE_ENV=development